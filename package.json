{
  "name": "westward",
  "version": "1.0.0",
  "description": "Story-first open-world frontier RPG with raycast combat, regional identity, gear progression, housing, and deterministic job-board systems.",
  "main": "src/main.js",
  "homepage": "https://westward-rpg.vercel.app",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev:py": "echo 'dev:py removed; atmosphere is bundled via Vite. Use \"npm run dev\" or \"npm run preview\" instead.' && exit 1",
    "build": "vite build",
    "build:itch": "vite build --base=./ --outDir dist-itch",
    "package:itch": "bash scripts/itch_package.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:syntax": "node --check web_game_playwright_client.mjs && node --check scripts/visual_diff.mjs && bash -n scripts/visual_regression_capture.sh && bash -n scripts/smoke_suite.sh",
    "test:smoke": "bash scripts/smoke_suite.sh",
    "test:render3d": "node scripts/render3d_loop_smoke.mjs",
    "test:visual:capture": "bash scripts/visual_regression_capture.sh",
    "test:visual": "node scripts/visual_diff.mjs",
    "test:visual:review": "node scripts/visual_diff.mjs --allow-missing-baselines",
    "test:visual:update": "node scripts/visual_diff.mjs --update",
    "qa": "npm test && npm run dev:lint && npm run test:smoke",
    "report:states": "python3 scripts/state_report.py output",
    "typecheck:ts": "tsc --noEmit",
    "bundle:assets": "ruby scripts/asset_bundler.rb generate",
    "verify:assets": "ruby scripts/asset_bundler.rb verify",
    "analyze:logs": "perl scripts/log_analyzer.pl output",
    "config:nginx": "php scripts/config_generator.php -t nginx",
    "config:apache": "php scripts/config_generator.php -t apache",
    "dev:check": "bash scripts/dev_tools.sh check",
    "dev:lint": "bash scripts/dev_tools.sh lint",
    "dev:full": "bash scripts/dev_tools.sh full"
  },
  "keywords": [
    "rpg",
    "game",
    "first-person",
    "raycasting",
    "javascript",
    "html5",
    "typescript",
    "python",
    "playwright",
    "i18n",
    "indie-game"
  ],
  "author": "coleyrockin <coleyrockin@aol.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coleyrockin/WestWardRPG.git"
  },
  "bugs": {
    "url": "https://github.com/coleyrockin/WestWardRPG/issues"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "fake-indexeddb": "^6.2.5",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
